# 全局
APP_ENV=development          # development 用 mock，production 用真实 SDK
LOG_LEVEL=INFO

# TDX Instance
TDX_HOST=0.0.0.0
TDX_PORT=9001
# TDX SDK 路径 (Windows 生产环境必填)
# 指向包含 tqcenter/ 和 TPythClient.dll 的目录
# 例如: D:/tdx_sdk  (目录下应有 tqcenter/__init__.py, tqcenter/tq.py, TPythClient.dll)
TDX_SDK_PATH=

# QMT Instance
QMT_HOST=0.0.0.0
QMT_PORT=9002
QMT_PATH=/path/to/miniQMT    # QMT 客户端路径
QMT_ACCOUNT_ID=               # QMT 资金账号
# QMT SDK 路径 (Windows 生产环境必填)
# 通常指向 miniQMT 安装目录下的 Lib 文件夹
# 例如: D:/miniQMT/Lib  (目录下应有 xtquant/__init__.py)
QMT_SDK_PATH=

# AKTools Instance
AKTOOLS_HOST=0.0.0.0
AKTOOLS_PORT=8080

# NestJS 连接
ALLOWED_ORIGINS=http://localhost:8001,http://localhost:8002
